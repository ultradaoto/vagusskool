<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
    <%- include('../partials/header') %>
    <main>
        <div class="container-custom py-10 md:py-16">
            <section class="style-shell px-6 py-8 md:px-10 md:py-12">
                <div class="pointer-events-none absolute inset-0">
                    <div class="absolute left-[-2rem] top-10 h-44 w-44 rounded-full bg-accent-purple/12 blur-3xl"></div>
                    <div class="absolute bottom-[-3rem] right-[-2rem] h-56 w-56 rounded-full bg-gold/18 blur-3xl"></div>
                </div>

                <div class="relative z-10">
                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
                        <div>
                            <span class="style-kicker mb-4">Editorial dashboard</span>
                            <h1 class="title font-cormorant text-4xl md:text-5xl text-accent-purple font-medium">Blog Admin</h1>
                            <p class="text-dark-text/60 mt-2">Manage your blog posts in the same light editorial system as the public site.</p>
                        </div>
                        <a href="/admin/blog/new" class="golden-button inline-flex items-center gap-2">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                            New Post
                        </a>
                    </div>

                    <% if (posts && posts.length > 0) { %>
                        <div class="section-shell !p-0 overflow-hidden">
                            <div class="overflow-x-auto">
                                <table class="w-full">
                                    <thead class="bg-white/70 border-b border-accent-purple/10">
                                <tr>
                                    <th class="text-left px-6 py-4 text-sm font-medium text-dark-text/70">Post</th>
                                    <th class="text-left px-6 py-4 text-sm font-medium text-dark-text/70">Status</th>
                                    <th class="text-left px-6 py-4 text-sm font-medium text-dark-text/70">Date</th>
                                    <th class="text-left px-6 py-4 text-sm font-medium text-dark-text/70">Tags</th>
                                    <th class="text-right px-6 py-4 text-sm font-medium text-dark-text/70">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-accent-purple/10">
                                <% posts.forEach(post => { %>
                                    <tr class="hover:bg-white/45 transition-colors">
                                        <td class="px-6 py-4">
                                            <div>
                                                <a href="/blog/<%= post.slug %>" target="_blank" class="font-medium text-accent-purple hover:text-gold transition-colors"><%= post.title %></a>
                                                <p class="text-sm text-dark-text/50 mt-1"><%= post.slug %></p>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <% if (post.published) { %>
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                    <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
                                                    Published
                                                </span>
                                            <% } else { %>
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                                                    <span class="w-1.5 h-1.5 bg-yellow-500 rounded-full"></span>
                                                    Draft
                                                </span>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4 text-sm text-dark-text/65">
                                            <div>
                                                <span>Created: <%= new Date(post.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                                                <% if (post.updatedAt !== post.createdAt) { %>
                                                    <p class="text-dark-text/40 text-xs mt-0.5">Updated: <%= new Date(post.updatedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
                                                <% } %>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex flex-wrap gap-1 max-w-xs">
                                                <% post.tags.slice(0, 3).forEach(tag => { %>
                                                    <span class="style-chip !text-xs !px-2 !py-0.5"><%= tag %></span>
                                                <% }) %>
                                                <% if (post.tags.length > 3) { %>
                                                    <span class="style-chip !text-xs !px-2 !py-0.5">+<%= post.tags.length - 3 %></span>
                                                <% } %>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex items-center justify-end gap-2">
                                                <a href="/blog/<%= post.slug %>" target="_blank" class="p-2 text-dark-text/50 hover:text-accent-purple hover:bg-white/70 rounded-lg transition-colors" title="View">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                                </a>
                                                <a href="/admin/blog/edit/<%= post.id %>" class="p-2 text-dark-text/50 hover:text-accent-purple hover:bg-white/70 rounded-lg transition-colors" title="Edit">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                                </a>
                                                <form action="/admin/blog/delete/<%= post.id %>" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to delete this post? This action cannot be undone.');">
                                                    <button type="submit" class="p-2 text-dark-text/50 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Delete">
                                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                                </tbody>
                            </table>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="section-shell p-12 text-center">
                            <div class="w-16 h-16 bg-white/70 rounded-full flex items-center justify-center mx-auto mb-4 shadow-sm">
                                <svg class="w-8 h-8 text-accent-purple/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                            </div>
                            <h3 class="font-cormorant text-2xl text-accent-purple mb-2">No posts yet</h3>
                            <p class="text-dark-text/60 mb-6">Get started by creating your first blog post.</p>
                            <a href="/admin/blog/new" class="golden-button inline-flex items-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                                Create First Post
                            </a>
                        </div>
                    <% } %>
                    </div>
            </section>
        </div>
    </main>
    <%- include('../partials/footer') %>
</body>
</html>
