<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
    <%- include('../partials/header') %>
    <main>
        <div class="container-custom py-10 md:py-16">
            <section class="style-shell px-6 py-8 md:px-10 md:py-12">
                <div class="pointer-events-none absolute inset-0">
                    <div class="absolute left-[-2rem] top-10 h-44 w-44 rounded-full bg-accent-purple/12 blur-3xl"></div>
                    <div class="absolute bottom-[-3rem] right-[-2rem] h-56 w-56 rounded-full bg-gold/18 blur-3xl"></div>
                </div>

                <div class="relative z-10">
                    <header class="text-center mb-12 md:mb-14">
                        <span class="style-kicker mb-6">Editorial insights</span>
                        <h1 class="title font-cormorant text-5xl md:text-6xl text-accent-purple mb-4 font-medium">
                            <%= typeof currentTag !== 'undefined' ? `Posts tagged "${currentTag}"` : 'Blog' %>
                        </h1>
                        <p class="subtitle font-cormorant text-xl md:text-2xl text-gold leading-tight max-w-2xl mx-auto">
                            <%= typeof currentTag !== 'undefined' ? 'Browse articles in this category' : 'Insights on vagus nerve stimulation, breathing techniques, and optimal wellness' %>
                        </p>
                    </header>

                    <% if (tags && tags.length > 0) { %>
                    <div class="flex flex-wrap justify-center gap-3 mb-12">
                        <a href="/blog" class="<%= typeof currentTag === 'undefined' ? 'blog-tag-active' : 'blog-tag' %>">
                            All
                        </a>
                        <% tags.forEach(tag => { %>
                            <a href="/blog/tag/<%= tag %>" class="<%= typeof currentTag !== 'undefined' && currentTag === tag ? 'blog-tag-active' : 'blog-tag' %>">
                                <%= tag %>
                            </a>
                        <% }) %>
                    </div>
                    <% } %>

                    <% if (posts && posts.length > 0) { %>
                        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                            <% posts.forEach(post => { %>
                                <article class="style-panel flex flex-col !p-0 overflow-hidden">
                                    <% if (post.featured_image) { %>
                                        <a href="/blog/<%= post.slug %>" class="block aspect-video overflow-hidden">
                                            <img src="<%= post.featured_image %>" alt="<%= post.title %>" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300">
                                        </a>
                                    <% } %>
                                    <div class="p-6 md:p-7 flex-1 flex flex-col">
                                        <div class="flex flex-wrap gap-2 mb-4">
                                            <% (post.tags || []).slice(0, 3).forEach(tag => { %>
                                                <span class="style-chip !text-xs !px-2.5 !py-1"><%= tag %></span>
                                            <% }) %>
                                        </div>
                                        <h2 class="font-cormorant text-2xl text-accent-purple mb-3 font-medium leading-tight">
                                            <a href="/blog/<%= post.slug %>" class="hover:text-gold transition-colors"><%= post.title %></a>
                                        </h2>
                                        <p class="text-dark-text/70 text-sm md:text-base mb-5 flex-1"><%= post.excerpt %></p>
                                        <div class="flex items-center justify-between gap-4 text-sm text-dark-text/55 border-t border-accent-purple/10 pt-4 mt-auto">
                                            <span>By <%= post.author %></span>
                                            <span><%= new Date(post.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                                        </div>
                                    </div>
                                </article>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div class="section-shell text-center py-16">
                            <p class="text-dark-text/60 text-lg">No posts found.</p>
                            <% if (typeof currentTag !== 'undefined') { %>
                                <a href="/blog" class="inline-block mt-4 text-accent-purple hover:text-gold transition-colors">View all posts</a>
                            <% } %>
                        </div>
                    <% } %>
                </div>
            </section>
        </div>
    </main>
    <%- include('../partials/footer') %>
</body>
</html>
